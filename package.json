{
  "name": "crazy-checkers",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint . --max-warnings 0 && tsx scripts/audit-reduced-motion.ts",
    "audit:motion": "tsx scripts/audit-reduced-motion.ts",
    "audit:event-icons": "tsx scripts/audit-event-icons.ts",
    "generate:event-icons": "tsx scripts/generate-event-icons.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "test:ai": "vitest run --config vitest.ai.config.ts --reporter=verbose",
    "test:perf": "node --expose-gc ./node_modules/.bin/vitest run --config vitest.perf.config.ts --reporter=verbose",
    "test:stress": "vitest run src/engine/events.stresstest.test.ts --reporter=verbose",
    "validate:ai": "tsx src/ai/validation/runValidation.ts",
    "validate:tier2": "tsx scripts/validateTier2.ts",
    "validate:tier2:quick": "tsx scripts/validateTier2.ts --quick",
    "validate:tier2:smoke": "tsx scripts/validateTier2.ts --smoke",
    "generate-puzzles": "tsx scripts/generatePuzzles.ts",
    "generate-puzzles:verbose": "tsx scripts/generatePuzzles.ts --verbose",
    "generate-puzzles:quick": "tsx scripts/generatePuzzles.ts --quick",
    "validate-puzzles": "vitest run src/data/puzzleData.test.ts",
    "check:bundle": "tsx scripts/check-bundle-split.ts",
    "check:bundle:tier1": "tsx scripts/tier1/check-bundle-size.ts",
    "gate:tier1": "vitest run src/test/classifiedChecklist/tier1 && tsx scripts/tier1/check-bundle-size.ts",
    "check:piece-stubs": "tsx scripts/check-piece-stubs.ts",
    "audit:css-colors": "tsx scripts/audit-css-colors.ts"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "idb": "^8.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
